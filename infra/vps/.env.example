# VPS API Proxy Configuration
API_KEY=your-shared-api-key-here
PORT=3100
OPENCLAW_WS_URL=ws://127.0.0.1:18789
OPENCLAW_HTTP_URL=http://127.0.0.1:18789
OPENCLAW_AUTH_TOKEN=your-openclaw-gateway-token
TENANT_DATA_DIR=/data/tenants
STATE_DIR=/data/state
ADMIN_APP_ORIGIN=*

# SSH credentials for terminal bridge (used by terminal-bridge.ts)
SSH_USER=root
SSH_PASSWORD=
# Or use key-based auth:
# SSH_PRIVATE_KEY_PATH=/root/.ssh/id_rsa
