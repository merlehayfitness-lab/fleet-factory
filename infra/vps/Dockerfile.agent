# Agent container image for Agency Factory
#
# Each agent runs its own OpenClaw gateway instance inside this container.
# Base image: Node.js 20 on Debian Bookworm (slim).
#
# Build:
#   docker build -t agency-factory/agent:latest -f Dockerfile.agent .
#
# Run:
#   docker run -d \
#     --name {vpsAgentId} \
#     -e AGENT_ID=... -e BUSINESS_SLUG=... -e DEPARTMENT_TYPE=... \
#     -e ANTHROPIC_API_KEY=... -e MODEL=... -e PORT=18789 \
#     -v /data/tenants/{slug}/workspace/workspace-{id}:/workspace:rw \
#     -v /data/tenants/{slug}/config:/config:ro \
#     -v /data/tenants/{slug}/memory/{id}:/memory:rw \
#     -p {hostPort}:18789 \
#     agency-factory/agent:latest

FROM node:22-bookworm-slim

# Install runtime dependencies: curl (health checks), jq (config filtering)
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl jq && \
    rm -rf /var/lib/apt/lists/*

# Install OpenClaw gateway globally
RUN npm install -g openclaw@latest

# Create working directories
RUN mkdir -p /workspace /config /memory /root/.openclaw

# Copy entrypoint script
COPY agent-entrypoint.sh /usr/local/bin/agent-entrypoint.sh
RUN chmod +x /usr/local/bin/agent-entrypoint.sh

# Default environment
ENV PORT=18789
ENV MEMORY_DIR=/memory

# Expose OpenClaw gateway port
EXPOSE 18789

# Health check: OpenClaw serves /healthz
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
  CMD curl -sf http://127.0.0.1:${PORT}/healthz || exit 1

ENTRYPOINT ["/usr/local/bin/agent-entrypoint.sh"]
